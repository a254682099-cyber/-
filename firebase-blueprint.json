{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and role information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "ledger_admin", "auditor", "collector", "readonly"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Ledger": {
      "title": "Ledger",
      "description": "A collaborative ledger container.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "members": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "uid": { "type": "string" },
              "role": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerUid"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Borrower or client information.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ledgerId": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "idCard": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ledgerId", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "A loan or investment transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ledgerId": { "type": "string" },
        "customerId": { "type": "string" },
        "principal": { "type": "number" },
        "interestRate": { "type": "number" },
        "interestInterval": { "type": "string", "enum": ["daily", "weekly", "monthly", "once"] },
        "termDays": { "type": "integer" },
        "startDate": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending_approval", "active", "overdue", "completed", "cancelled"] },
        "collectorUid": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ledgerId", "customerId", "principal", "interestRate", "startDate", "status"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "Record of all sensitive operations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ledgerId": { "type": "string" },
        "uid": { "type": "string" },
        "action": { "type": "string" },
        "targetId": { "type": "string" },
        "oldValue": { "type": "string" },
        "newValue": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["ledgerId", "uid", "action", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications for ledger events.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "ledgerId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "ledgerId", "title", "message", "type", "read", "timestamp"]
    },
    "CollectionTask": {
      "title": "Collection Task",
      "description": "A specific instance of a collection task (principal or interest) with a temporary status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "ledgerId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["principal", "interest"] },
        "status": { "type": "string", "enum": ["pending", "notified", "collected", "other"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "ledgerId", "date", "type", "status"]
    },
    "SystemMember": {
      "title": "System Member",
      "description": "Global members who can access multiple ledgers.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "accessibleLedgerIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "name", "role", "accessibleLedgerIds"]
    },
    "Payment": {
      "title": "Payment",
      "description": "A payment record for an order.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "orderId": { "type": "string" },
        "ledgerId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["interest", "principal"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "uid": { "type": "string" },
        "userName": { "type": "string" }
      },
      "required": ["orderId", "ledgerId", "amount", "type", "timestamp", "uid"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/ledgers/{ledgerId}": { "schema": "Ledger", "description": "Ledgers" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customers" },
    "/orders/{orderId}": { "schema": "Order", "description": "Orders" },
    "/auditLogs/{logId}": { "schema": "AuditLog", "description": "Audit logs" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/collectionTasks/{taskId}": { "schema": "CollectionTask", "description": "Collection tasks with temporary statuses" },
    "/systemMembers/{memberId}": { "schema": "SystemMember", "description": "Global system members" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Payment records" }
  }
}
