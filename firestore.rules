rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is a system member (logged in via anonymous auth but has a user doc)
    function isSystemMember() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSystemMember == true;
    }

    // Get the user's role from their user document safely
    function getUserRole() {
      return (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid))) 
             ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role 
             : null;
    }

    // Check if the user has a specific role
    function hasRole(role) {
      return getUserRole() == role;
    }

    // Check if the user is an admin or super_admin
    function isAdmin() {
      return hasRole('admin') || hasRole('super_admin');
    }

    // Check if the user has access to a specific ledger via accessibleLedgerIds
    function hasLedgerAccess(ledgerId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAll(['accessibleLedgerIds']) && 
             ledgerId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accessibleLedgerIds;
    }

    // Check if the user is a member of the ledger document being evaluated (for ledgers collection)
    function isMemberOfThisLedger() {
      return isAuthenticated() && 
             (resource.data.ownerUid == request.auth.uid || 
              (resource.data.keys().hasAll(['memberUids']) && request.auth.uid in resource.data.memberUids));
    }

    // Check if the user is a member of a specific ledger ID (for sub-resources)
    function isMemberOfLedgerId(ledgerId) {
      let ledger = get(/databases/$(database)/documents/ledgers/$(ledgerId)).data;
      return isAuthenticated() && 
             (ledger.ownerUid == request.auth.uid || 
              (ledger.keys().hasAll(['memberUids']) && request.auth.uid in ledger.memberUids));
    }

    // Check if the user has read access to the ledger document itself
    function canReadThisLedger(ledgerId) {
      return isAdmin() || isMemberOfThisLedger() || hasLedgerAccess(ledgerId);
    }

    // Check if the user has write access to the ledger document itself
    function canWriteThisLedger(ledgerId) {
      return isAdmin() || isMemberOfThisLedger() || hasLedgerAccess(ledgerId);
    }

    // Check if the user has read access to a ledger's data (customers, orders, etc.)
    function canReadLedgerData(ledgerId) {
      return isAdmin() || isMemberOfLedgerId(ledgerId) || hasLedgerAccess(ledgerId);
    }

    // Check if the user has write access to a ledger's data (customers, orders, etc.)
    function canWriteLedgerData(ledgerId) {
      return isAdmin() || isMemberOfLedgerId(ledgerId) || hasLedgerAccess(ledgerId);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users Collection
    match /users/{userId} {
      // Anyone can read user profiles (needed for display names)
      allow read: if isAuthenticated();
      
      // Users can update their own profile, but cannot change their role unless they are an admin
      // The default admin email can bootstrap their own admin role
      allow create: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && (
          // If they are not an admin, they cannot create an admin role
          (!('role' in request.resource.data) || request.resource.data.role != 'admin' && request.resource.data.role != 'super_admin') ||
          // Allow the default admin email to bootstrap their role
          (request.auth.token.email == 'a254682099@gmail.com' && request.auth.token.email_verified == true)
        ))
      );
      
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (request.auth.uid == userId && (
          // If they are not an admin, they cannot change their role
          (!('role' in request.resource.data) || request.resource.data.role == resource.data.role) ||
          // Allow the default admin email to bootstrap their role
          (request.auth.token.email == 'a254682099@gmail.com' && request.auth.token.email_verified == true)
        ))
      );
      
      allow delete: if isAdmin();
    }

    // System Members Collection (managed by admins)
    match /systemMembers/{memberId} {
      // Admins can do anything. System members can read their own data (though they usually read from users collection)
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Ledgers Collection
    match /ledgers/{ledgerId} {
      allow read: if canReadThisLedger(ledgerId);
      allow create: if isAuthenticated(); // Anyone can create a ledger
      allow update: if canWriteThisLedger(ledgerId);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.ownerUid == request.auth.uid);
    }

    // Customers Collection
    match /customers/{customerId} {
      allow read: if canReadLedgerData(resource.data.ledgerId);
      allow create: if canWriteLedgerData(request.resource.data.ledgerId);
      allow update, delete: if canWriteLedgerData(resource.data.ledgerId);
    }

    // Orders Collection
    match /orders/{orderId} {
      allow read: if canReadLedgerData(resource.data.ledgerId);
      allow create: if canWriteLedgerData(request.resource.data.ledgerId);
      allow update, delete: if canWriteLedgerData(resource.data.ledgerId);
      
      // Payments Subcollection
      match /payments/{paymentId} {
        allow read: if canReadLedgerData(get(/databases/$(database)/documents/orders/$(orderId)).data.ledgerId);
        allow create: if canWriteLedgerData(get(/databases/$(database)/documents/orders/$(orderId)).data.ledgerId);
        allow update, delete: if canWriteLedgerData(get(/databases/$(database)/documents/orders/$(orderId)).data.ledgerId);
      }
    }

    // Collection Tasks
    match /collectionTasks/{taskId} {
      allow read: if canReadLedgerData(resource.data.ledgerId);
      allow create: if canWriteLedgerData(request.resource.data.ledgerId);
      allow update, delete: if canWriteLedgerData(resource.data.ledgerId);
    }

    // Notifications
    match /notifications/{notificationId} {
      // Users can only read and update their own notifications
      allow read, update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      // System can create notifications for anyone
      allow create: if isAuthenticated();
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Audit Logs
    match /auditLogs/{logId} {
      allow read: if canReadLedgerData(resource.data.ledgerId);
      allow create: if isAuthenticated(); // Anyone can create an audit log
      allow update, delete: if false; // Audit logs should be immutable
    }
  }
}
